rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidMsDossier(data) {
      return data.keys().hasAll(['id', 'material', 'supplier'])
        && data.id is string
        && data.material is string
        && data.supplier is string;
    }

    match /ms_dossiers/{dossierId} {
      // Basic rule: Allow authenticated users to read and write dossiers
      // assuming a simple internal app for the company's team.
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(dossierId) 
                    && isValidMsDossier(incoming());
      allow update: if isSignedIn() 
                    && isValidId(dossierId) 
                    && isValidMsDossier(incoming());
      allow delete: if isSignedIn() && isValidId(dossierId);
    }
  }
}
